# GitLurker — copy into `.env.dev` at repo root and/or `backend/.env`. No secrets in git.

# GitHub (AUTH_TOKEN or GITHUB_TOKEN)
AUTH_TOKEN=

# Nostr
LURKER_KEY=
NOSTR_RELAYS=ws://127.0.0.1:7777
NOSTR_USE_PUBLIC_RELAYS=false
NOSTR_PUBLISH_ENABLED=false

# Scheduler / GitHub
GITHUB_PRIMARY_LIMIT_PER_HOUR=5000
GITHUB_SCHEDULER_BUDGET_PER_HOUR=4000
REFRESH_INTERVAL_SECONDS=3600
GITHUB_MAX_CONCURRENT_REQUESTS=6

# API routes backed by GitHub
API_GITHUB_RATE_LIMIT_PER_MINUTE=45
API_GITHUB_CACHE_TTL_SECONDS=90
GITLURKER_DEV_DUMMY_API=false

# Operators (hex, comma-separated)
GITLURKER_OPERATOR_PUBKEYS=
GITLURKER_REVIEWER_PUBKEYS=

# Optional: GITLURKER_ENV, DEBUG, ALLOWED_HOSTS, SECRET_KEY

NOSTR_EOSE_GRACE_MS=800

# Vite (root `.env.dev` or frontend/.env.local); browser only sees VITE_*
VITE_GITLURKER_PUBKEY=
VITE_NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net,wss://nostr.mom
VITE_NOSTR_USE_PUBLIC_RELAYS=false
VITE_NOSTR_REVIEWER_PUBKEYS=
VITE_NOSTR_EOSE_GRACE_MS=800
VITE_DEV_DUMMY_DATA=false
GITLURKER_DEV_API_ORIGIN=
